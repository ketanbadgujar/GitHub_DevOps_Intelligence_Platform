# ── Dev mode (npm run dev) ────────────────────────────────────────────────────
# Vite proxy rewrites /api → http://localhost:8000, so you usually don't need this.
# Override only if your gateway runs on a non-default host/port.
VITE_API_BASE_URL=http://localhost:8000

# ── Production / Docker build ─────────────────────────────────────────────────
# In Docker, Nginx proxies /api → api-gateway:8000 internally.
# Leave VITE_API_BASE_URL unset (or set to /api) for production builds.
